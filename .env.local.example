# Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_tu-key-aqui
# Alternativa al anon key (mismo valor en proyectos nuevos de Supabase)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_tu-key-aqui

# Requerida en servidor para crear/gestionar usuarios (API /api/users)
# Supabase → Settings → API → service_role (nunca expongas en el cliente)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# Opcional: URL pública de la app (útil si usas dominio propio en Vercel)
# NEXT_PUBLIC_SITE_URL=https://tu-app.vercel.app

# Impresión directa de etiquetas (Tomate T-IM5002, 3×4 cm)
# Tomate Bluetooth: usa puerto COM (Administrador de dispositivos → COM de T-IM5002)
PRINT_COM_PORT=COM8
PRINT_BAUD_RATE=9600
PRINT_MODE=escpos
# Alternativa: impresora Windows (driver POS-58 / Generic) — suele no funcionar en Tomate
PRINTER_NAME=POS-58
NEXT_PUBLIC_PRINT_SERVER_URL=http://127.0.0.1:3847
