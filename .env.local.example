# ─── Supabase (Settings → API) ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_tu-key-aqui
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_tu-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ─── URL pública (Vercel: https://tu-proyecto.vercel.app) ────────────────────
# También configurar en Supabase → Authentication → URL Configuration:
#   Site URL = esta misma URL
#   Redirect URLs = https://tu-proyecto.vercel.app/**
NEXT_PUBLIC_SITE_URL=https://tu-proyecto.vercel.app

# ─── Correo SMTP (Gmail + contraseña de aplicación) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=tu-correo@gmail.com
SMTP_FROM_NAME=ParqueoSys

# ─── Impresión automática (PC del operador con la Tomate) ────────────────────
# En Vercel NO hace falta configurar impresión.
# En cada PC con impresora:
#   1. Instalar Node.js + driver LABEL
#   2. Copiar el proyecto (o clonar) y ejecutar scripts\start-print-server.bat
#   3. Abrir https://parqueo-two.vercel.app en ESE mismo PC
#
# Local / .env del PC operador (para print:server):
PRINTER_NAME=LABEL
PRINT_VIA=windows
PRINT_MODE=gdi
NEXT_PUBLIC_PRINT_SERVER_URL=http://127.0.0.1:3847
# NEXT_PUBLIC_PRINT_CHROME_FALLBACK=true
NEXT_PUBLIC_LABEL_PAGE_WIDTH_MM=40
NEXT_PUBLIC_LABEL_PAGE_HEIGHT_MM=30
LABEL_TSPL_WIDTH_MM=40
LABEL_TSPL_HEIGHT_MM=30
